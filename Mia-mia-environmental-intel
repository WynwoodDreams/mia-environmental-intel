import { useState, useEffect, useCallback } from "react";

/*
  M.I.A. ENVIRONMENTAL INTEL — v4.0
  Mobile-first responsive · High contrast text · Live + fallback data
*/

// ─── PALETTE (higher contrast) ───
const P = {
  bg: "#080810",
  panel: "#0e0e18",
  panel2: "#141420",
  border: "#222236",
  cyan: "#00d4ff",
  cyanSoft: "#66e0ff",
  pink: "#ff3070",
  pinkSoft: "#ff6090",
  green: "#2eec8a",
  amber: "#ffcc44",
  white: "#f2f2fa",
  // KEY: much brighter text tiers
  text: "#d0d0e0",       // primary body text
  textSoft: "#a8a8c0",   // secondary info
  label: "#8888a4",       // labels, less important
  dim: "#5c5c78",         // least important (borders, decorative only)
};

const FONT = `'JetBrains Mono', 'SF Mono', 'Fira Code', 'Cascadia Code', monospace`;
const FLOOD = 3.2;

// ─── FALLBACK DATA ───
function todayAt(h, m) {
  const d = new Date(); d.setHours(h, m, 0, 0); return d.toISOString();
}
const FALLBACK = {
  temp: 82, feelsLike: 87, humidity: 74, dewpoint: 73,
  pressure: 1015.2, pressureIn: 29.98, wind: 12, gust: 18,
  windDir: 135, visibility: 10.0, heatIdx: 87,
  desc: "Partly Cloudy", waterLevel: 1.47,
  hilo: [
    { t: todayAt(6, 12), v: "2.81", type: "H" },
    { t: todayAt(12, 38), v: "0.14", type: "L" },
    { t: todayAt(18, 45), v: "2.64", type: "H" },
    { t: todayAt(23, 55), v: "0.42", type: "L" },
  ],
  hourly: Array.from({ length: 25 }, (_, i) => ({
    t: todayAt(i, 0),
    v: String((1.5 + 1.3 * Math.sin((i - 3) * Math.PI / 6.2)).toFixed(2)),
  })),
  forecast: [
    { name: "Tonight", temp: 78, unit: "F", short: "Partly Cloudy", wind: "SE 10 mph", precip: 20 },
    { name: "Thursday", temp: 86, unit: "F", short: "Scattered Showers", wind: "SE 12 mph", precip: 40 },
    { name: "Thu Night", temp: 77, unit: "F", short: "Mostly Cloudy", wind: "E 8 mph", precip: 25 },
    { name: "Friday", temp: 88, unit: "F", short: "Sunny", wind: "SE 10 mph", precip: 10 },
    { name: "Fri Night", temp: 76, unit: "F", short: "Clear", wind: "E 6 mph", precip: 5 },
    { name: "Saturday", temp: 89, unit: "F", short: "Mostly Sunny", wind: "S 8 mph", precip: 15 },
  ],
};
const dirLabel = d => ["N","NNE","NE","ENE","E","ESE","SE","SSE","S","SSW","SW","WSW","W","WNW","NW","NNW"][Math.round(d / 22.5) % 16];

// ─── RESPONSIVE HOOK ───
function useWidth() {
  const [w, setW] = useState(typeof window !== "undefined" ? window.innerWidth : 960);
  useEffect(() => {
    const h = () => setW(window.innerWidth);
    window.addEventListener("resize", h);
    return () => window.removeEventListener("resize", h);
  }, []);
  return w;
}

// ─── COMPONENTS ───
function Dot({ color = P.cyan, size = 6 }) {
  return <span style={{
    display: "inline-block", width: size, height: size, borderRadius: "50%",
    background: color, boxShadow: `0 0 ${size + 2}px ${color}`,
    animation: "dot-pulse 2.5s ease-in-out infinite", flexShrink: 0,
  }} />;
}

function SectionLabel({ children }) {
  return (
    <div style={{
      fontFamily: FONT, fontSize: 10, fontWeight: 600, color: P.label,
      letterSpacing: 3, textTransform: "uppercase", marginBottom: 12,
      display: "flex", alignItems: "center", gap: 8,
    }}>
      <span style={{ width: 14, height: 1, background: P.cyan, display: "inline-block", flexShrink: 0 }} />
      {children}
    </div>
  );
}

function MetricBox({ label, value, unit, sub, color = P.cyan, large = false, mobile = false }) {
  return (
    <div style={{
      background: P.panel, border: `1px solid ${P.border}`, borderRadius: 6,
      padding: large ? (mobile ? "16px" : "20px 22px") : (mobile ? "12px 14px" : "14px 16px"),
      display: "flex", flexDirection: "column", gap: 4,
    }}>
      <div style={{ fontFamily: FONT, fontSize: mobile ? 8 : 9, color: P.label, letterSpacing: 2 }}>{label}</div>
      <div style={{
        fontFamily: FONT, fontSize: large ? (mobile ? 26 : 32) : (mobile ? 18 : 22),
        fontWeight: 700, color, lineHeight: 1, marginTop: 2,
      }}>
        {value ?? <span style={{ opacity: 0.25 }}>—</span>}
        {unit && <span style={{ fontSize: large ? (mobile ? 11 : 14) : (mobile ? 9 : 11), color: P.textSoft, fontWeight: 400, marginLeft: 3 }}>{unit}</span>}
      </div>
      {sub && <div style={{ fontFamily: FONT, fontSize: mobile ? 8 : 9, color: P.textSoft, lineHeight: 1.5, marginTop: 2 }}>{sub}</div>}
    </div>
